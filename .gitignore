# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js / build output
/.next/
/out/
/build
/dist

# Testing / coverage
/coverage

# Caches
.turbo
.eslintcache
*.tsbuildinfo
next-env.d.ts

# Local demo data store
.data/

# Environment variables (never commit secrets)
.env
.env.*
!.env.example

# Vercel
.vercel

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Editors / IDEs
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*.swo

# OS files
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# Misc
*.pem
