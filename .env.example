# ── Supabase — PRODUCTION (leave EMPTY to run in local demo mode) ──
# Get these from your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only key for admin/import scripts. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ── Supabase — DEMO (a SEPARATE project, fully isolated from production) ──
# Optional. When set, a "Coba Mode Demo" button appears on the login page and
# demo mode talks ONLY to this project. See README → "Mode Demo".
NEXT_PUBLIC_SUPABASE_DEMO_URL=
NEXT_PUBLIC_SUPABASE_DEMO_ANON_KEY=

# ── Cron backup (optional) ──
CRON_SECRET=
